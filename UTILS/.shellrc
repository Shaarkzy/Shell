#Shark Shell Alias Command
ls=ls --color=auto
grep=grep --color=auto
fgrep=fgrep --color=auto
egrep=egrep --color=auto
ll=ls -alF
la=ls -A
l=ls -CF
alert=notify-send --urgency=low -i $([ $? = 0 ] && echo terminal || echo error) $(history|tail -n1|sed -e \s/^\s*[0-9]\+\s*//;s/[;&|]\s*alert$//\)
mirror=/snap/bin/scrcpy
python=python3
obf=python3 ~/.obfuscate.py
p=python3
c=clear
nv=vim
g=git clone
i=apt install
ir=apt remove
ii=apt update && apt upgrade
d=rm
dd=rm -rf
gc=git add .; git commit -m
gp=git push origin
tem=acpi  -t
bot=python ~/gemini.py
start=ngrok http --url=fish-social-koi.ngrok-free.app
